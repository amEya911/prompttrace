{
  "name": "prompttrace-monorepo",
  "version": "1.0.0",
  "description": "Developer tool to track, analyze, and optimize LLM token usage.",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*",
    "examples/*"
  ],
  "scripts": {
    "clean": "rm -rf node_modules packages/**/dist apps/**/dist",
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  }
}